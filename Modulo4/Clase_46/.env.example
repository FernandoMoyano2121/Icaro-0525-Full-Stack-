# Variables de entorno — Clase 46 Nodemailer
# Copiá este archivo como .env y completá con tus credenciales reales
# NUNCA subas el archivo .env a GitHub

# ─────────────────────────────────────────────────────────────────────
# OPCIÓN A: Mailtrap (recomendado para clase y desarrollo)
# Creá una cuenta gratis en https://mailtrap.io
# Entrá a tu Inbox → SMTP Settings → seleccioná "Nodemailer"
# y copiá los valores que te muestra
# ─────────────────────────────────────────────────────────────────────
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=tu_usuario_mailtrap
MAIL_PASS=tu_password_mailtrap
MAIL_FROM="Tienda Icaro <no-reply@tienda-icaro.com>"

# ─────────────────────────────────────────────────────────────────────
# OPCIÓN B: Gmail (para producción)
# Requiere "Contraseña de aplicación" de Google
# (no es tu contraseña normal — ver README para el proceso)
# ─────────────────────────────────────────────────────────────────────
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=tu_cuenta@gmail.com
# MAIL_PASS=xxxx_xxxx_xxxx_xxxx   ← contraseña de aplicación de 16 caracteres
# MAIL_FROM="Tu Nombre <tu_cuenta@gmail.com>"

# Puerto del servidor Express (ejemplo 05)
PORT=3000
